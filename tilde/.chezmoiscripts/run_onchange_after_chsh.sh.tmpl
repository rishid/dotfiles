{{- $isMacOS := eq .chezmoi.os "darwin" -}}
{{- $isLinux := and (eq .chezmoi.osRelease.id "ubuntu" "debian") (not .ephemeral) -}}
{{- if or $isMacOS $isLinux -}}
#!/usr/bin/env bash

set -euo pipefail

{{- if $isMacOS }}

# macOS: Find fish shell (Homebrew installs to different paths on Intel vs Apple Silicon)
FISH_PATH=""
for p in /opt/homebrew/bin/fish /usr/local/bin/fish; do
    if [[ -x "$p" ]]; then
        FISH_PATH="$p"
        break
    fi
done

if [[ -z "$FISH_PATH" ]]; then
    FISH_PATH=$(command -v fish 2>/dev/null || true)
fi

if [[ -z "$FISH_PATH" ]]; then
    echo "Fish not found. Run homebrew install script first."
    exit 1
fi

# Add fish to /etc/shells if not already listed
if ! grep -qF "$FISH_PATH" /etc/shells; then
    echo "Adding $FISH_PATH to /etc/shells..."
    echo "$FISH_PATH" | sudo tee -a /etc/shells > /dev/null
fi

# Change default shell to fish
if [[ "$SHELL" != "$FISH_PATH" ]]; then
    echo "Changing default shell to $FISH_PATH..."
    chsh -s "$FISH_PATH"
fi

{{- else if $isLinux }}

chsh -s "$(which fish)"

{{- end }}
{{- end }}
