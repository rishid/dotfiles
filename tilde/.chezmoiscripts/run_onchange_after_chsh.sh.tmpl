{{- $isMacOS := eq .chezmoi.os "darwin" -}}
{{- $isLinux := and (eq .chezmoi.osRelease.id "ubuntu" "debian") (not .ephemeral) -}}
{{- if or $isMacOS $isLinux -}}
#!/usr/bin/env bash

# NOTE: set -e intentionally omitted — shell changes may fail on managed/MDM
# machines due to security policy; we warn and continue rather than aborting
# chezmoi apply.
set -uo pipefail

{{- if $isMacOS }}

# macOS: Find fish shell (Homebrew installs to different paths on Intel vs Apple Silicon)
FISH_PATH=""
for p in /opt/homebrew/bin/fish /usr/local/bin/fish; do
    if [[ -x "$p" ]]; then
        FISH_PATH="$p"
        break
    fi
done
if [[ -z "$FISH_PATH" ]]; then
    FISH_PATH=$(command -v fish 2>/dev/null || true)
fi

if [[ -z "$FISH_PATH" ]]; then
    echo "WARNING: fish not found — skipping shell change. Run 'brew install fish' first."
    exit 0
fi

# Add fish to /etc/shells if not already listed.
# MDM/security policies may block sudo on some machines; try gracefully.
if ! grep -qF "$FISH_PATH" /etc/shells; then
    echo "Adding $FISH_PATH to /etc/shells..."
    # Try sudo bash to avoid tee being blocked by security policy
    if sudo bash -c "echo '$FISH_PATH' >> /etc/shells" 2>/dev/null; then
        echo "Added $FISH_PATH to /etc/shells"
    else
        echo "WARNING: could not write to /etc/shells (security policy may be blocking sudo)."
        echo "To fix manually:  echo '$FISH_PATH' | sudo tee -a /etc/shells"
        echo "Skipping default shell change."
        exit 0
    fi
fi

# Change default shell to fish
if [[ "$SHELL" != "$FISH_PATH" ]]; then
    echo "Changing default shell to $FISH_PATH..."
    if chsh -s "$FISH_PATH" 2>/dev/null; then
        echo "Default shell changed to fish."
    else
        echo "WARNING: chsh failed (may require IT/MDM approval on managed Macs)."
        echo "To fix manually:  chsh -s $FISH_PATH"
    fi
else
    echo "Default shell is already fish."
fi

{{- else if $isLinux }}

chsh -s "$(which fish)"

{{- end }}
{{- end }}
