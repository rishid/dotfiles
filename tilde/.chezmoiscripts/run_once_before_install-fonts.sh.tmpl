{{ if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

set -euo pipefail

# Install JetBrains Mono Nerd Font (patched with icons for tide/terminal)
mkdir -p ~/Library/Fonts

FONT_ZIP=$(mktemp /tmp/JetBrainsMonoNF.XXXXXX.zip)
trap 'rm -f "$FONT_ZIP"' EXIT

echo "Downloading JetBrainsMono Nerd Font..."
curl -fL \
    "https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.zip" \
    -o "$FONT_ZIP" \
    || { echo "Failed to download JetBrainsMono Nerd Font zip"; exit 1; }

echo "Extracting fonts to ~/Library/Fonts/..."
# Extract only the regular-weight variants (skip NL/ligature variants and Windows fonts)
unzip -o "$FONT_ZIP" \
    "JetBrainsMonoNerdFont-Regular.ttf" \
    "JetBrainsMonoNerdFont-Bold.ttf" \
    "JetBrainsMonoNerdFont-Italic.ttf" \
    "JetBrainsMonoNerdFont-BoldItalic.ttf" \
    -d ~/Library/Fonts/ \
    || { echo "Extracting all fonts (specific names not matched)"; unzip -o "$FONT_ZIP" -d ~/Library/Fonts/; }

echo "JetBrains Mono Nerd Font installed successfully"
{{ end -}}
