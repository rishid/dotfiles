#!/usr/bin/env bash
# Install agent skills via npx skills CLI
# Re-runs whenever this file changes — to add a skill, add a line here and run chezmoi apply
set -euo pipefail

# Disable telemetry
export DISABLE_TELEMETRY=1

# Ensure mise shims are in PATH (provides npx from mise-managed Node)
export PATH="$HOME/.local/share/mise/shims:$PATH"

# On macOS, also ensure Homebrew is in PATH
if [[ "$(uname)" == "Darwin" ]]; then
    if [[ -x /opt/homebrew/bin/brew ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    elif [[ -x /usr/local/bin/brew ]]; then
        eval "$(/usr/local/bin/brew shellenv)"
    fi
fi

# Activate mise to regenerate shims if needed
if command -v mise &>/dev/null; then
    mise reshim 2>/dev/null || true
fi

if ! command -v npx &>/dev/null; then
    echo "npx not found — install Node via 'mise install node' first, skipping skills"
    exit 0
fi

# Helper to add a skill to Claude Code
add_skill() {
    npx skills add "$1" -a claude-code "${@:2}" -y
}

echo "Installing agent skills..."

# Personal skills from dotfiles repo (skills/ at repo root, one subdir per skill)
# Note: .chezmoiroot is "tilde" so sourceDir is ~/.dotfiles/tilde/; go up one level for repo root
add_skill "{{ .chezmoi.sourceDir }}/.." --all

# Third-party skills (from GitHub)
add_skill anthropics/skills@frontend-design

add_skill akin-ozer/cc-devops-skills --skill dockerfile-generator
add_skill akin-ozer/cc-devops-skills --skill github-actions-generator
add_skill vercel-labs/agent-skills --skill vercel-react-best-practices

echo "Agent skills installed successfully."
