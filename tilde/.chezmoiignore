# -*-mode:gitignore-*- vim:ft=gotmpl.gitignore

# ~/.local/share/chezmoi/.chezmoiignore
# =============================================================================
# Read by chezmoi when choosing repository files to copy to home directory.
#
# This list defines globs to ignore, and supports Go's text/template language.
# See https://www.chezmoi.io/docs/reference/#chezmoiignore

# Claude Code (managed by the app itself)
.claude/settings.json

# Shell
.config/fish/fish_variables
.config/fish/fish_history

# History
.lesshst
.wget-hsts
.*_history

{{ if ne .chezmoi.os "darwin" -}}
# macOS files (excluded on non-macOS)
**/.DS_Store
.CFUserTextEncoding
.Trash
Library/
tilde/private_Library/
{{ end }}

{{ if eq .chezmoi.os "darwin" -}}
# systemd is Linux-only
.config/systemd/
{{ end }}

# fish auto-generates this on 4.3+ upgrade; its own comment says to delete it.
# Ignoring prevents a chezmoi-delete → fish-recreate loop.
.config/fish/conf.d/fish_frozen_key_bindings.fish
